{
  "identifier": "desktop-capability",
  "platforms": [
    "macOS",
    "windows",
    "linux"
  ],
  "windows": [
    "main"
  ],
  "permissions": [
    "window-state:default",
    "global-shortcut:default",
    "dialog:default",
    "fs:default",
    "opener:default",
    {
      "identifier": "fs:allow-rename",
      "allow": [
        {
          "path": "$HOME/*"
        },
        { "path": "$DESKTOP/**/*" }
      ]
    },
    {
      "identifier": "fs:allow-rename",
      "allow": [
        {
          "path": "$HOME/**/*"
        },
        { "path": "$DESKTOP/**/*" }
      ]
    },
    {
      "identifier": "fs:allow-read-dir",
      "allow": [
        {
          "path": "$HOME/**/*"
        },
        { "path": "$DESKTOP/**/*" }
      ]
    },
    {
      "identifier": "fs:allow-open",
      "allow": [
        {
          "path": "$HOME/**/*"
        },
        { "path": "$DESKTOP/**/*" }
      ]
    },
    {
      "identifier": "opener:allow-open-path",
      "allow": [
        {
          "path": "$HOME/**/*"
        },
        { "path": "$DESKTOP/**/*" }
      ]
    },
    {
      "identifier": "fs:allow-copy-file",
      "allow": [
        {
          "path": "$HOME/**/*"
        },
        { "path": "$DESKTOP/**/*" }
      ]
    }
  ]
}
